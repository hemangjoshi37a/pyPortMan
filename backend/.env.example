# pyPortMan Backend Environment Variables

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Database URL
# SQLite (default): sqlite:///./pyportman.db
# PostgreSQL: postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./pyportman.db

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Market Hours (IST)
MARKET_START=09:15
MARKET_END=15:30

# Scheduler Settings
REFRESH_INTERVAL_MINUTES=5
SNAPSHOT_INTERVAL_MINUTES=15
